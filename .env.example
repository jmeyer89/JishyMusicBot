DISCORD_TOKEN=your-bot-token-here

# Leave this BLANK if you want the bot to work in any server it joins.
#
# Only fill this in if you're testing changes to the bot and want them
# to show up right away in your own server(s). Paste the server IDs
# separated by commas. When set, the bot's commands ONLY work in those
# listed servers and nowhere else.
INSTANT_SYNC_GUILD_IDS=

# Spotify app credentials. Only CLIENT_ID and CLIENT_SECRET are required —
# /play uses the Spotify Web API (Client Credentials flow) to look up tracks
# and to canonicalise free-text searches before resolving on YouTube.
# REDIRECT_URI and REFRESH_TOKEN are only needed if you also want to run
# spotify_auth.py for future user-scoped features.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_REFRESH_TOKEN=
